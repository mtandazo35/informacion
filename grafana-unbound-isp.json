          },
          {
            "matcher": { "id": "byName", "options": "Tipo" },
            "properties": [{ "id": "custom.width", "value": 70 }]
          },
          {
            "matcher": { "id": "byName", "options": "Consultas" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "percentage", "steps": [
                { "color": "blue", "value": 0 },
                { "color": "red",  "value": 80 }
              ]}}
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Consultas" }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": { "Value #A": "Consultas", "domain": "Dominio", "qtype": "Tipo" }
          }
        }
      ],
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "topk(20, unbound_domain_queries_total{instance=\"$instance\"})",
        "instant": true,
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 33,
      "type": "table",
      "title": "Top 30 — IP de origen → Dominio destino (pares más frecuentes)",
