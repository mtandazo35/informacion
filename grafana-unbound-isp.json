{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",     "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus",  "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel",      "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel",      "id": "heatmap",    "name": "Heatmap",     "version": "" },
    { "type": "panel",      "id": "piechart",   "name": "Pie chart",   "version": "" },
    { "type": "panel",      "id": "bargauge",   "name": "Bar gauge",   "version": "" },
    { "type": "panel",      "id": "table",      "name": "Table",       "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Unbound DNS ISP — letsencrypt/unbound_exporter + log-exporter",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["dns", "unbound", "isp"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Unbound DNS ISP",
  "uid": "unbound-isp-v2",
  "version": 2,
  "templating": {
    "list": [
      {
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {
          "selected": false,
          "text": "205.235.2.143",
          "value": "205.235.2.143"
        },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(unbound_up, instance)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "instance",
        "options": [],
        "query": {
          "query": "label_values(unbound_up, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Instancia"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Consultas totales",
      "description": "Total de consultas DNS en el rango seleccionado.",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "rgb(31,120,193)", "mode": "fixed" },
          "unit": "short",
          "mappings": [{ "type": "special", "options": { "match": "null", "result": { "text": "N/A" } } }]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none", "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(increase(unbound_queries_total{instance=\"$instance\"}[$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Consultas / seg",
      "description": "Tasa de consultas DNS (promedio 5 minutos).",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "rgb(31,120,193)", "mode": "fixed" },
          "unit": "reqps", "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none", "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rate(unbound_queries_total{instance=\"$instance\"}[5m]))",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tasa de aciertos en cache",
      "description": "Porcentaje de consultas respondidas desde cache.",
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": 0  },
            { "color": "yellow", "value": 50 },
            { "color": "green",  "value": 80 }
          ]},
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background", "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rate(unbound_cache_hits_total{instance=\"$instance\"}[5m])) / sum(rate(unbound_queries_total{instance=\"$instance\"}[5m])) * 100",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tiempo de recursión promedio",
      "description": "Tiempo promedio de resolución recursiva (resolución no cacheada).",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 2,
          "color": { "fixedColor": "rgb(31,120,193)", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none", "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "unbound_recursion_time_seconds_avg{instance=\"$instance\"} * 1000",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Memoria en cache",
      "description": "Bytes en uso por msg cache y rrset cache.",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "fixedColor": "rgb(31,120,193)", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none", "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(unbound_memory_caches_bytes{instance=\"$instance\"})",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Tiempo activo",
      "description": "Tiempo en ejecución del proceso Unbound.",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "fixedColor": "rgb(31,120,193)", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none", "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "unbound_time_up_seconds_total{instance=\"$instance\"}",
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "type": "heatmap",
      "title": "Distribución de tiempo de respuesta",
      "description": "Mapa de calor de tiempos de respuesta DNS (incluye recursión y cache).",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "scaleDistribution": { "type": "linear" } } },
        "overrides": []
      },
      "options": {
        "calculate": true,
        "cellGap": 1,
        "color": { "exponent": 0.5, "fill": "#3274D9", "mode": "opacity", "scheme": "Oranges", "steps": 128 },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": false },
        "tooltip": { "mode": "single", "yHistogram": true },
        "yAxis": { "axisPlacement": "left", "decimals": 0, "min": "0", "unit": "s" }
      },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(unbound_response_time_seconds_bucket{instance=\"$instance\"}[5m])",
        "format": "heatmap",
        "legendFormat": "{{le}}",
        "refId": "A"
      }]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Aciertos / Fallos en cache",
      "description": "Proporción de hits vs misses en el rango de tiempo seleccionado.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Aciertos" }, "properties": [{ "id": "color", "value": { "fixedColor": "#56A64B", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Fallos"   }, "properties": [{ "id": "color", "value": { "fixedColor": "#E02F44", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(increase(unbound_cache_hits_total{instance=\"$instance\"}[$__range]))",   "legendFormat": "Aciertos", "refId": "A" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(increase(unbound_cache_misses_total{instance=\"$instance\"}[$__range]))", "legendFormat": "Fallos",   "refId": "B" }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Consultas",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Consultas por tipo de registro",
      "description": "Desglose por tipo DNS: A, AAAA, MX, CNAME, PTR, HTTPS, etc.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          { "matcher": { "id": "byValue", "options": { "op": "gte", "reducer": "allIsZero", "value": 0 } },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": true, "viz": false } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(unbound_query_types_total{instance=\"$instance\"}[5m])",
        "legendFormat": "{{type}}", "refId": "A"
      }]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Respuestas por código (RCODE)",
      "description": "NOERROR = éxito, NXDOMAIN = dominio no existe, SERVFAIL = error del servidor, REFUSED = rechazado.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "NXDOMAIN" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "SERVFAIL" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byValue", "options": { "op": "gte", "reducer": "allIsZero", "value": 0 } },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": true, "viz": false } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(unbound_answer_rcodes_total{instance=\"$instance\"}[5m])",
        "legendFormat": "{{rcode}}", "refId": "A"
      }]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "DNSSEC",
      "description": "Respuestas con flag AD (autenticadas), bogus rechazadas y RRsets inválidos.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Seguras (AD)"     }, "properties": [{ "id": "color", "value": { "fixedColor": "#56A64B",     "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Bogus (SERVFAIL)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#E02F44",     "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "RRset inválido"   }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_answers_secure_total{instance=\"$instance\"}[5m])", "legendFormat": "Seguras (AD)",     "refId": "A" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_answers_bogus{instance=\"$instance\"}[5m])",        "legendFormat": "Bogus (SERVFAIL)", "refId": "B" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_rrset_bogus_total{instance=\"$instance\"}[5m])",   "legendFormat": "RRset inválido",   "refId": "C" }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Transporte: TCP / UDP / IPv6 / TLS",
      "description": "Desglose de consultas por protocolo de transporte.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_query_tcp_total{instance=\"$instance\"}[5m])",    "legendFormat": "TCP entrante", "refId": "A" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_query_tcpout_total{instance=\"$instance\"}[5m])", "legendFormat": "TCP saliente", "refId": "B" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_query_udpout_total{instance=\"$instance\"}[5m])", "legendFormat": "UDP saliente", "refId": "C" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_query_ipv6_total{instance=\"$instance\"}[5m])",   "legendFormat": "IPv6",         "refId": "D" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_query_tls_total{instance=\"$instance\"}[5m])",    "legendFormat": "TLS",          "refId": "E" }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Seguridad y Prefetch",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "panels": []
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Consultas rechazadas (ACL)",
      "description": "Consultas bloqueadas por listas de control de acceso.",
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(increase(unbound_unwanted_queries_total{instance=\"$instance\"}[$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Respuestas no deseadas",
      "description": "Posible cache poisoning / spoofing si el valor sube.",
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(increase(unbound_unwanted_replies_total{instance=\"$instance\"}[$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Prefetches",
      "description": "Entradas de cache renovadas proactivamente antes de expirar.",
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "rgb(31,120,193)", "mode": "fixed" } },
        "overrides": []
      },
      "options": { "colorMode": "none", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(increase(unbound_prefetches_total{instance=\"$instance\"}[$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Expiradas servidas (stale)",
      "description": "Respuestas servidas desde cache vencida (serve-expired activo).",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "rgb(31,120,193)", "mode": "fixed" } },
        "overrides": []
      },
      "options": { "colorMode": "none", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(increase(unbound_expired_total{instance=\"$instance\"}[$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Indicadores de consultas (flags)",
      "description": "RD (recursión deseada), CD (validación DNSSEC desactivada), EDNS, DO (DNSSEC OK).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          { "matcher": { "id": "byValue", "options": { "op": "gte", "reducer": "allIsZero", "value": 0 } },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": true, "viz": false } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_query_flags_total{instance=\"$instance\"}[1m])",        "legendFormat": "{{flag}}",      "refId": "A" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_query_edns_present_total{instance=\"$instance\"}[1m])", "legendFormat": "EDNS OPT",      "refId": "B" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_query_edns_DO_total{instance=\"$instance\"}[1m])",      "legendFormat": "DO (DNSSEC OK)","refId": "C" }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Cola de solicitudes pendientes",
      "description": "Solicitudes en espera de resolución. Excedidos indica sobrecarga.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Excedidos" }, "properties": [{ "id": "color", "value": { "fixedColor": "#E02F44", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_request_list_current_all{instance=\"$instance\"})",            "legendFormat": "En cola (total)",   "refId": "A" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_request_list_current_user{instance=\"$instance\"})",           "legendFormat": "En cola (usuario)", "refId": "B" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_request_list_exceeded_total{instance=\"$instance\"}[5m])",    "legendFormat": "Excedidos",         "refId": "C" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(unbound_request_list_overwritten_total{instance=\"$instance\"}[5m])", "legendFormat": "Sobreescritos",     "refId": "D" }
      ]
    },
    {
      "id": 21,
      "type": "row",
      "title": "Cache y Memoria",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "panels": []
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Entradas activas en cache",
      "description": "Número de registros almacenados en msg cache, rrset cache e infra cache.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 1, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_msg_cache_count{instance=\"$instance\"})",   "legendFormat": "Cache de mensajes", "refId": "A" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_rrset_cache_count{instance=\"$instance\"})", "legendFormat": "Cache de RRsets",   "refId": "B" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_infra_cache_count{instance=\"$instance\"})", "legendFormat": "Cache de infra",    "refId": "C" }
      ]
    },
    {
      "id": 23,
      "type": "bargauge",
      "title": "Uso de memoria por componente",
      "description": "Bytes en uso por cache de mensajes, RRsets, módulos y DoH.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_memory_caches_bytes{instance=\"$instance\", cache=\"message\"})", "legendFormat": "Cache mensajes", "refId": "A" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_memory_caches_bytes{instance=\"$instance\", cache=\"rrset\"})",   "legendFormat": "Cache RRsets",   "refId": "B" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_memory_modules_bytes{instance=\"$instance\"})",                  "legendFormat": "Módulos",        "refId": "C" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "sum(unbound_memory_doh_bytes{instance=\"$instance\"})",                      "legendFormat": "DoH",            "refId": "D" }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Clientes y Dominios — Top consultas (requiere unbound-log-exporter)",
