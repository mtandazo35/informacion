# /etc/default/olt-monitor
# Defaults: bind to localhost only. Use SSH tunnel to access from your laptop:
#   ssh -L 8000:localhost:8000 root@SERVER
# Then open http://localhost:8000 in your browser.

BIND_HOST=127.0.0.1
BIND_PORT=8000

# To enable BasicAuth, uncomment and edit (format: user:password):
# OLT_MONITOR_AUTH=admin:CHANGEME
