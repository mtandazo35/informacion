#!/bin/bash
###################### CONFIGURAR RANGO VPN  ##################

# Rango Privado para el VPN (No debe existir en su red)
IP_VPN="10.8.0.0"
MASCARA_VPN="255.255.255.0"

# Configuracion OPENVPN
# IP publica del cloud
get_public_ip=$(grep -m 1 -oE '^[0-9]{1,3}(\.[0-9]{1,3}){3}$' <<< "$(wget -T 10 -t 1 -4qO- "http://ip1.dynupdate.no-ip.com/" || curl -m 10 -4Ls "http://ip1.dynupdate.no-ip.com/")")

# Protocolo de conexion
protocol=tcp

# Puerto de Conexion (Por defecto 1194)
port="1194"

# Nombre de la instalacion (se usa para directorio de clientes y branding)
BRAND="VPN-ZABBIX"
CONF_DIR="/etc/openvpn/${BRAND}"
CRED_FILE="/root/vpn-zabbix-credentials.txt"

ver_debian=$(grep -Po 'VERSION="[0-9]+ \(\K[^)]+' /etc/os-release)

# Ubicacion plugin
if [[ "$ver_debian" = "buster" ]]; then
    url_plugin="/usr/lib/x86_64-linux-gnu/openvpn/plugins/openvpn-plugin-auth-pam.so"
else
    url_plugin="/usr/lib/openvpn/openvpn-plugin-auth-pam.so"
fi

######################   FIN CONFIGURACION     ##################

save_credentials() {
    local user="$1" pass="$2" ipvpn="$3"
    umask 077
    {
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] usuario=$user pass=$pass ip_vpn=$ipvpn server=$get_public_ip"
    } >> "$CRED_FILE"
}

function newuser() {
    # Excluir rutas.sh del conteo para que el primer usuario sea .2 de forma determinista
    NEXTIP=$(find "$CONF_DIR" -maxdepth 1 -type f ! -name 'rutas.sh' | wc -l)
    NEXTIP=$((NEXTIP + 2))

    if [[ "$NEXTIP" -gt 254 ]]; then
        dialog --title "ERROR" --msgbox "Se alcanzo el limite de usuarios para el rango ${IP_VPN}/24" 10 50
        return 1
    fi

    IPVPN=${IP_VPN%.0}.$NEXTIP

    USERVPN="$(tr -dc a-z0-9 < /dev/urandom | head -c 12)"
    PASSVPN="$(tr -dc a-z0-9 < /dev/urandom | head -c 12)"

    # --force-badname esta deprecado y sera removido en Debian 13; usar --allow-bad-names
    # cuando este disponible. Cubre Debian 9 (buster) hasta 13 (trixie) y mas alla.
    if adduser --help 2>&1 | grep -q -- '--allow-bad-names'; then
        BADNAME_FLAG=--allow-bad-names
    else
        BADNAME_FLAG=--force-badname
    fi

    adduser "$USERVPN" \
        --gecos "$USERVPN,RoomNumber,WorkPhone,HomePhone" \
        --disabled-password \
        "$BADNAME_FLAG" \
        --no-create-home \
        --shell /usr/sbin/nologin >/dev/null

    echo "$USERVPN:$PASSVPN" | chpasswd

    echo "ifconfig-push $IPVPN $MASCARA_VPN

    " > "$CONF_DIR/$USERVPN"

    save_credentials "$USERVPN" "$PASSVPN" "$IPVPN"

    clear
    echo "###########################################################"
    echo -e "                \033[0;31mDATOS USER VPN\033[0m (Guardar datos)             "
    echo "###########################################################"
    echo ""
    echo -e "\033[0;31mIP VPN USER : \e[38;5;198m$IPVPN\033[0m"
    echo -e "\033[0;31m     USUARIO: \e[38;5;198m$USERVPN\033[0m"
    echo -e "\033[0;31m  CONTRASENA: \e[38;5;198m$PASSVPN\033[0m"
    echo ""
    echo -e "  (Tambien guardado en \033[0;33m$CRED_FILE\033[0m)"
    echo ""
    echo "###########################################################"
    echo -e "  \033[0;31mCONFIGURACION MIKROTIK\033[0m (Copiar & pegar consola mikrotik)"
    echo "###########################################################"
    echo ""

    echo -e "\e[38;5;36m/interface ovpn-client\033[0m
\e[38;5;206madd \e[38;5;22mconnect-to\033[0m=$get_public_ip \e[38;5;22mport\033[0m=$port \e[38;5;22mcipher\033[0m=aes256 \e[38;5;22mdisabled\033[0m=no \e[38;5;22mname\033[0m=vpn-zabbix \e[38;5;22mpassword\033[0m=$PASSVPN \e[38;5;22muser\033[0m=$USERVPN"
    echo ""
}

rg1=""
rg12=""
rg2=""
rg3=""
rg4=""
rg5=""
rg6=""
rg7=""
rg8=""
rg9=""
rg10=""

function newred() {
    exec 3>&1
    VALUES=$(dialog --separate-widget $'\n' --ok-label "Agregar rangos" \
        --backtitle "$BRAND" \
        --title "Agregar rangos clientes" \
        --cancel-label "Salir" \
        --form "Agregar nuevo rango cliente ejm: 192.168.1.0/24" \
        20 50 0 \
        "USUARIO VPN :" 1 1 ""        1 17 23 0 \
        ""              2 1 "$rg12"   2 0 0 0 \
        "Red 1:"        3 1 "$rg1"    3 10 30 0 \
        "Red 2:"        4 1 "$rg2"    4 10 30 0 \
        "Red 3:"        5 1 "$rg3"    5 10 30 0 \
        "Red 4:"        6 1 "$rg4"    6 10 30 0 \
        "Red 5:"        7 1 "$rg5"    7 10 30 0 \
        "Red 6:"        8 1 "$rg6"    8 10 30 0 \
        "Red 7:"        9 1 "$rg7"    9 10 30 0 \
        "Red 8:"       10 1 "$rg8"   10 10 30 0 \
        "Red 9:"       11 1 "$rg9"   11 10 30 0 \
        "Red 10:"      12 1 "$rg10"  12 10 30 0 \
        2>&1 1>&3)
    exec 3>&-

    RANG=($VALUES)

    if [[ -z "${RANG[0]}" ]]; then
        return 0
    fi

    if [[ ! -f "$CONF_DIR/${RANG[0]}" ]]; then
        dialog --title "ERROR" --msgbox 'El usuario VPN es Incorrecto' 10 40
        newred
        return 0
    fi

    clear

    NEWRANGOS=""

    for ((i = 1; i < ${#RANG[@]}; i++)); do
        if [[ -z "${RANG[$i]}" ]]; then
            continue
        fi

        if ! [[ "${RANG[$i]}" =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}/[0-9]{1,2}$ ]]; then
            echo "Formato invalido: ${RANG[$i]} (se espera CIDR ej. 192.168.1.0/24). Omitida."
            continue
        fi

        # Buscar duplicados tanto en rutas.sh (server) como en el CCD (cliente)
        if grep -qw "${RANG[$i]}" "$CONF_DIR/rutas.sh" || \
           grep -qw "$(echo "${RANG[$i]}" | cut -d/ -f1)" "$CONF_DIR/${RANG[0]}"; then
            echo ""
            echo "El rango ${RANG[$i]} ya existe y no fue agregado."
            echo ""
            continue
        fi

        NEWRANGOS=${RANG[$i]}

        redes=${RANG[$i]}
        red=$(echo "$redes" | cut -d "/" -f 1)
        cidr=$(echo "$redes" | cut -d "/" -f 2)

        value=$((0xffffffff ^ ((1 << (32 - cidr)) - 1)))
        mask="$(((value >> 24) & 0xff)).$(((value >> 16) & 0xff)).$(((value >> 8) & 0xff)).$((value & 0xff))"

        user=($(head -n 1 "$CONF_DIR/${RANG[0]}"))
        gateway=${user[1]}

        # ip route en lugar de /sbin/route: net-tools ya no viene por defecto en Debian 12.
        # 'replace' + '|| true' hacen el script up idempotente y tolerante a reinicios.
        echo "/sbin/ip route replace ${RANG[$i]} via $gateway 2>/dev/null || true" >> "$CONF_DIR/rutas.sh"
        echo "iroute $red $mask" >> "$CONF_DIR/${RANG[0]}"
    done

    if [[ -n "$NEWRANGOS" ]]; then
        chmod 0755 "$CONF_DIR/rutas.sh"
        systemctl restart openvpn-server@server

        dialog --title "EXITO" --msgbox 'Los Rangos fueron agregados correctamente' 10 40
    fi
}

if ! [[ -x "$(command -v dialog)" ]]; then
    apt-get update
    apt-get install -y perl dialog
fi

OPTIONS=(1 "Instalar y Configurar OPENVPN SERVER"
    2 "Agregar usuario vpn (Uno por cada Mikrotik)"
    3 "Agregar Redes IPs de los clientes")

CHOICE=$(dialog --clear \
    --backtitle "$BRAND" \
    --title "Configurar Tunel VPN" \
    --cancel-label "Salir" \
    --ok-label "Aceptar" \
    --menu "Seleccione la opcion correcta (Presionar Enter)" \
    15 60 4 \
    "${OPTIONS[@]}" \
    2>&1 >/dev/tty)

clear

case $CHOICE in
1)
    clear

    read -N 999999 -t 0.001
    if readlink /proc/$$/exe | grep -q "dash"; then
        echo 'Este instalador debe ejecutarse con "bash", no con "sh".'
        exit 1
    fi

    # Detect OpenVZ 6
    if [[ $(uname -r | cut -d "." -f 1) -eq 2 ]]; then
        echo "El sistema esta ejecutando un nucleo antiguo, que es incompatible con este instalador."
        exit 1
    fi

    # Detect OS
    if grep -qs "ubuntu" /etc/os-release; then
        os="ubuntu"
        os_version=$(grep 'VERSION_ID' /etc/os-release | cut -d '"' -f 2 | tr -d '.')
        group_name="nogroup"
    elif [[ -e /etc/debian_version ]]; then
        os="debian"
        os_version=$(grep -oE '[0-9]+' /etc/debian_version | head -1)
        group_name="nogroup"
    elif [[ -e /etc/centos-release ]]; then
        os="centos"
        os_version=$(grep -oE '[0-9]+' /etc/centos-release | head -1)
        group_name="nobody"
    elif [[ -e /etc/fedora-release ]]; then
        os="fedora"
        os_version=$(grep -oE '[0-9]+' /etc/fedora-release | head -1)
        group_name="nobody"
    else
        echo "Este instalador parece estar ejecutandose en una distribucion no compatible.
Las distribuciones admitidas son Ubuntu, Debian, CentOS y Fedora."
        exit 1
    fi

    if [[ "$os" == "ubuntu" && "$os_version" -lt 1804 ]]; then
        echo "Se requiere Ubuntu 18.04 o superior para usar este instalador."
        exit 1
    fi

    if [[ "$os" == "debian" && "$os_version" -lt 9 ]]; then
        echo "Se requiere Debian 9 o superior para usar este instalador."
        exit 1
    fi

    if [[ "$os" == "centos" && "$os_version" -lt 7 ]]; then
        echo "Se requiere CentOS 7 o superior para usar este instalador."
        exit 1
    fi

    if ! grep -q sbin <<< "$PATH"; then
        echo '$PATH no incluye sbin. Intente usar "su -" en lugar de "su".'
        exit 1
    fi

    if [[ "$EUID" -ne 0 ]]; then
        echo "Este instalador debe ejecutarse con privilegios de superusuario."
        exit 1
    fi

    if [[ ! -e /dev/net/tun ]] || ! (exec 7<>/dev/net/tun) 2>/dev/null; then
        echo "El sistema no tiene el dispositivo TUN disponible."
        exit 1
    fi

    if [[ $(ip -4 addr | grep inet | grep -vEc '127(\.[0-9]{1,3}){3}') -eq 1 ]]; then
        ip=$(ip -4 addr | grep inet | grep -vE '127(\.[0-9]{1,3}){3}' | cut -d '/' -f 1 | grep -oE '[0-9]{1,3}(\.[0-9]{1,3}){3}')
    else
        number_of_ip=$(ip -4 addr | grep inet | grep -vEc '127(\.[0-9]{1,3}){3}')
        echo
        echo "Seleccionar IPv4 del servidor Cloud (Publica o Privada)"
        ip -4 addr | grep inet | grep -vE '127(\.[0-9]{1,3}){3}' | cut -d '/' -f 1 | grep -oE '[0-9]{1,3}(\.[0-9]{1,3}){3}' | nl -s ') '
        read -p "IPv4 address [1]: " ip_number
        until [[ -z "$ip_number" || "$ip_number" =~ ^[0-9]+$ && "$ip_number" -le "$number_of_ip" ]]; do
            echo "$ip_number: invalid selection."
            read -p "IPv4 address [1]: " ip_number
        done
        [[ -z "$ip_number" ]] && ip_number="1"
        ip=$(ip -4 addr | grep inet | grep -vE '127(\.[0-9]{1,3}){3}' | cut -d '/' -f 1 | grep -oE '[0-9]{1,3}(\.[0-9]{1,3}){3}' | sed -n "$ip_number"p)
    fi

    if systemd-detect-virt -cq; then
        mkdir /etc/systemd/system/openvpn-server@server.service.d/ 2>/dev/null
        echo "[Service]
LimitNPROC=infinity" > /etc/systemd/system/openvpn-server@server.service.d/disable-limitnproc.conf
    fi

    if [[ "$os" = "debian" || "$os" = "ubuntu" ]]; then
        apt-get update
        apt-get install -y openvpn openssl ca-certificates
    elif [[ "$os" = "centos" ]]; then
        yum install -y epel-release
        yum install -y openvpn openssl ca-certificates tar
    else
        dnf install -y openvpn openssl ca-certificates tar
    fi

    # Get easy-rsa
    wget -O ~/easy-rsa.tgz https://github.com/OpenVPN/easy-rsa/releases/download/v3.1.2/EasyRSA-3.1.2.tgz
    mkdir -p /etc/openvpn/easy-rsa
    tar xzf ~/easy-rsa.tgz --strip-components=1 --no-same-owner --directory /etc/openvpn/easy-rsa
    rm -f ~/easy-rsa.tgz
    cd /etc/openvpn/easy-rsa/ || exit 1
    echo "set_var EASYRSA_KEY_SIZE 2048" > vars

    SERVER_CN="cn_$(head /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 16 | head -n 1)"
    echo "$SERVER_CN" > SERVER_CN_GENERATED
    SERVER_NAME="server"
    echo "$SERVER_NAME" > SERVER_NAME_GENERATED

    ./easyrsa init-pki
    EASYRSA_CA_EXPIRE=3650 ./easyrsa --batch --req-cn="$SERVER_CN" build-ca nopass
    EASYRSA_CERT_EXPIRE=3650 ./easyrsa --batch build-server-full "$SERVER_NAME" nopass
    EASYRSA_CRL_DAYS=3650 ./easyrsa gen-crl
    openssl dhparam -out dh.pem 2048

    cp pki/ca.crt pki/private/ca.key "pki/issued/$SERVER_NAME.crt" "pki/private/$SERVER_NAME.key" /etc/openvpn/easy-rsa/pki/crl.pem /etc/openvpn/server
    cp dh.pem /etc/openvpn/server
    chmod 644 /etc/openvpn/server/crl.pem
    chmod o+x /etc/openvpn/server/

    # Generate server.conf
    echo "local $ip
port $port
proto $protocol
dev tun
ca ca.crt
cert server.crt
key server.key
dh dh.pem
auth SHA1
verify-client-cert none
username-as-common-name
tmp-dir \"/etc/openvpn/tmp\"
plugin $url_plugin login
script-security 2
up \"$CONF_DIR/rutas.sh\"
explicit-exit-notify 0
client-config-dir \"$CONF_DIR\"
topology subnet
server $IP_VPN $MASCARA_VPN
keepalive 10 120
data-ciphers AES-256-CBC
data-ciphers-fallback AES-256-CBC
persist-key
persist-tun
status openvpn-status.log
verb 3
crl-verify crl.pem" > /etc/openvpn/server/server.conf

    # Enable net.ipv4.ip_forward for the system
    echo 'net.ipv4.ip_forward=1' > /etc/sysctl.d/30-openvpn-forward.conf
    echo 1 > /proc/sys/net/ipv4/ip_forward

    if sestatus 2>/dev/null | grep "Current mode" | grep -q "enforcing" && [[ "$port" != 1194 ]]; then
        if ! hash semanage 2>/dev/null; then
            if [[ "$os_version" -eq 7 ]]; then
                yum install -y policycoreutils-python
            else
                dnf install -y policycoreutils-python-utils
            fi
        fi
        semanage port -a -t openvpn_port_t -p "$protocol" "$port"
    fi

    mkdir -p "$CONF_DIR"

    cat > "$CONF_DIR/rutas.sh" <<'EOF'
#!/bin/sh
# Up-script de OpenVPN: rutas a redes detras de cada MikroTik.
# Generado por el instalador vpn-zabbix. La opcion 3 agrega lineas aqui.
# Cada linea usa 'ip route replace ... || true' para ser idempotente
# y tolerante a fallos sin matar el servicio OpenVPN.
EOF
    chmod 0755 "$CONF_DIR/rutas.sh"
    mkdir -p /etc/openvpn/tmp
    chmod 700 /etc/openvpn/tmp

    systemctl enable --now openvpn-server@server.service

    if [[ "$ver_debian" = "stretch" ]]; then
        cat <<EOT > /lib/systemd/system/openvpn-server@.service
[Unit]
Description=OpenVPN service for %I
After=syslog.target network-online.target
Wants=network-online.target
Documentation=man:openvpn(8)
Documentation=https://community.openvpn.net/openvpn/wiki/Openvpn24ManPage
Documentation=https://community.openvpn.net/openvpn/wiki/HOWTO

[Service]
Type=notify
PrivateTmp=true
RuntimeDirectory=openvpn-server
RuntimeDirectoryMode=0710
WorkingDirectory=/etc/openvpn/server
ExecStart=/usr/sbin/openvpn --status %t/openvpn-server/status-%i.log --status-version 2 --suppress-timestamps --config %i.conf
CapabilityBoundingSet=CAP_IPC_LOCK CAP_NET_ADMIN CAP_NET_BIND_SERVICE CAP_NET_RAW CAP_SETGID CAP_SETUID CAP_AUDIT_WRITE CAP_SYS_CHROOT CAP_DAC_OVERRIDE
LimitNPROC=10
DeviceAllow=/dev/null rw
DeviceAllow=/dev/net/tun rw

[Install]
WantedBy=multi-user.target
EOT
    fi

    systemctl daemon-reload
    systemctl restart openvpn-server@server

    echo ""
    newuser
    echo ""
    exit 0
    ;;
2)
    if ! [[ -x "$(command -v openvpn)" ]]; then
        dialog --title "ERROR" --msgbox 'No esta instalado servidor OPENVPN, ejecute la opcion 1' 10 40
        exit 1
    fi

    chmod 0755 "$CONF_DIR/rutas.sh"
    newuser
    ;;
3)
    if ! [[ -x "$(command -v openvpn)" ]]; then
        dialog --title "ERROR" --msgbox 'No esta instalado servidor OPENVPN, ejecute la opcion 1' 10 40
        exit 1
    fi

    clear
    newred
    ;;
esac
